# ─── Supabase ─────────────────────────────────────────────────────────────────
# Required. Get from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase DB password (used by scripts/setup-db-url.mjs to build DATABASE_URL)
SUPABASE_DB_PASSWORD=

# Run `npm run db:setup` after filling the above — it writes DATABASE_URL to .env
# Or paste the full Transaction Pooler URL from Supabase Dashboard → Settings → Database:
# DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-X-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# Storage bucket name (default: website-assets)
STORAGE_BUCKET=website-assets

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# Required for the command orchestrator. Get from: platform.openai.com/api-keys
OPENAI_API_KEY=
# Optional: defaults to gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# ─── n8n ──────────────────────────────────────────────────────────────────────
# Optional. Without these the n8n panel shows "Could not reach n8n" gracefully.
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=

# ─── Claude Worker ────────────────────────────────────────────────────────────
# Optional. Jobs stay queued in DB if the worker is offline.
CLAUDE_WORKER_API_URL=http://localhost:4002
CLAUDE_WORKER_API_KEY=

# ─── Vercel ───────────────────────────────────────────────────────────────────
# Optional. Without these, deployments are recorded in DB but not triggered on Vercel.
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=

# ─── Vercel environment variable checklist ────────────────────────────────────
# Add all of the above (except DATABASE_URL — use Vercel's Postgres integration
# or paste the pooler URL directly) to:
#   Vercel Dashboard → Project → Settings → Environment Variables
# Mark NEXT_PUBLIC_* vars as available to all environments.
# Mark service keys (SUPABASE_SERVICE_ROLE_KEY, OPENAI_API_KEY, etc.) as
# Production + Preview only — never expose them to the browser.
